# ============================================================
#  ELLA EATS — Required Environment Variables
#  Copy this file to .env for local development.
#  For production, set these in Netlify Environment Variables.
#  NEVER commit .env or real API keys to source control.
# ============================================================

# Google Cloud API key — must have Places API (New) enabled
GOOGLE_API_KEY=your_google_api_key_here

# TripAdvisor Content API key (free plan)
TA_API_KEY=your_tripadvisor_api_key_here
